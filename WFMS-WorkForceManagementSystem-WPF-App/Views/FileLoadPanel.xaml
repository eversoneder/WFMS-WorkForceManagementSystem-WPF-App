<UserControl x:Class="WFMS_WorkForceManagementSystem_WPF_App.Views.FileLoadPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WFMS_WorkForceManagementSystem_WPF_App.Views"
             mc:Ignorable="d"
             Height="{Binding Path=Height, RelativeSource={RelativeSource AncestorType=Window}}"
             Width="{Binding Path=Width, RelativeSource={RelativeSource AncestorType=Window}}">


    <Grid Background="#F5F5F5">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="TxtStatus" Text="Loading default timesheet file..." FontSize="24" Margin="0,0,0,20" HorizontalAlignment="Center" Foreground="#067BF9" TextWrapping="Wrap" MaxWidth="500"/>
            <Button x:Name="BtnBrowse" Content="Browse Device for File..." Width="180" Height="35" Click="BtnBrowse_Click"/>
        </StackPanel>
    </Grid>

</UserControl>
